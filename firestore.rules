rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a multi-tenant authorization model for the ClientReview system. 
     * It relies heavily on "Authorization Independence" via data denormalization. By copying 
     * ownership and membership data (studioOwnerId, studioMembers, allowedClientUserIds) 
     * directly onto child documents (Projects, Assets, Feedback), we ensure that security 
     * checks are performant and do not require expensive recursive lookups or get() calls 
     * for most operations.
     *
     * DATA STRUCTURE
     * - /user_profiles/{userId}: Private user data.
     * - /studios/{studioId}: Root tenancy entity.
     * - /studios/{studioId}/projects/{projectId}: Projects within a studio.
     * - /studios/{studioId}/projects/{projectId}/assets/{assetId}: Deliverables within a project.
     * - /studios/{studioId}/projects/{projectId}/assets/{assetId}/feedback/{feedbackId}: Time-coded feedback.
     *
     * KEY SECURITY DECISIONS
     * - Ownership: Enforced via UID matching on user profiles and studioOwnerId fields.
     * - Collaborative Access: Managed via a 'members' map on Studio documents, which is 
     *   denormalized down the hierarchy.
     * - Client Access: Managed via an 'allowedClientUserIds' array on Project documents, 
     *   also denormalized downwards.
     * - Prototyping Flexibility: Rules focus strictly on authorization and relational 
     *   integrity (UID/ID matching) rather than strict schema or type validation.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Checks if the user is the primary studio owner based on denormalized data
    function isStudioOwner(data) {
      return isSignedIn() && (data.ownerUserId == request.auth.uid || data.studioOwnerId == request.auth.uid);
    }

    // Checks if the user is an agency member based on denormalized members map
    function isStudioMember(data) {
      return isSignedIn() && (
        (data.members != null && data.members[request.auth.uid] != null) || 
        (data.studioMembers != null && data.studioMembers[request.auth.uid] != null)
      );
    }

    // Checks if the user is a client granted access to this specific branch of the hierarchy
    function isAllowedClient(data) {
      return isSignedIn() && (request.auth.uid in data.allowedClientUserIds);
    }

    // Helper to check if a user has any access to a studio (as owner or member)
    // Used primarily for path-based list lookups on subcollections
    function hasStudioAccess(studioId) {
      let studio = get(/databases/$(database)/documents/studios/$(studioId)).data;
      return isStudioOwner(studio) || isStudioMember(studio);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for UserProfile. Users can only manage their own profile.
     * @path /user_profiles/{userId}
     * @allow (get) user 'abc' reads /user_profiles/abc
     * @deny (list) user 'abc' attempts to list all user profiles
     * @principle Ownership: Restricts access to a user's own data tree.
     */
    match /user_profiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other profiles
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Studios. Only owners or members can read. Only owners can update/delete.
     * @path /studios/{studioId}
     * @allow (create) user 'abc' creates a studio with ownerUserId 'abc'
     * @deny (update) user 'xyz' attempts to update a studio they don't own
     * @principle Shared Access: Uses ownerUserId and members map for authorization.
     */
    match /studios/{studioId} {
      allow get: if isStudioOwner(resource.data) || isStudioMember(resource.data);
      allow list: if isSignedIn(); // Filtering happens on the client side via where() queries
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if resource != null && isStudioOwner(resource.data) && request.resource.data.ownerUserId == resource.data.ownerUserId;
      allow delete: if resource != null && isStudioOwner(resource.data);
    }

    /**
     * @description Rules for Projects. Access granted to studio staff or explicitly invited clients.
     * @path /studios/{studioId}/projects/{projectId}
     * @allow (get) client 'c1' reads project where 'c1' is in allowedClientUserIds
     * @deny (create) client attempts to create a project
     * @principle Denormalization: Checks access using fields copied from the parent studio.
     */
    match /studios/{studioId}/projects/{projectId} {
      allow get: if isStudioOwner(resource.data) || isStudioMember(resource.data) || isAllowedClient(resource.data);
      allow list: if hasStudioAccess(studioId);
      allow create: if isSignedIn() && (isStudioOwner(request.resource.data) || isStudioMember(request.resource.data)) && request.resource.data.studioId == studioId;
      allow update: if resource != null && (isStudioOwner(resource.data) || isStudioMember(resource.data)) && request.resource.data.studioId == studioId;
      allow delete: if resource != null && isStudioOwner(resource.data);
    }

    /**
     * @description Rules for Assets. Access mirrors parent Project permissions.
     * @path /studios/{studioId}/projects/{projectId}/assets/{assetId}
     * @allow (get) studio member reads asset in their project
     * @deny (update) client attempts to update asset status
     * @principle Denormalization: Relies on project-level access fields copied to the asset.
     */
    match /studios/{studioId}/projects/{projectId}/assets/{assetId} {
      allow get: if isStudioOwner(resource.data) || isStudioMember(resource.data) || isAllowedClient(resource.data);
      allow list: if hasStudioAccess(studioId); 
      allow create: if isSignedIn() && (isStudioOwner(request.resource.data) || isStudioMember(request.resource.data)) && request.resource.data.projectId == projectId;
      allow update: if resource != null && (isStudioOwner(resource.data) || isStudioMember(resource.data)) && request.resource.data.projectId == projectId;
      allow delete: if resource != null && (isStudioOwner(resource.data) || isStudioMember(resource.data));
    }

    /**
     * @description Rules for Feedback. Clients can create feedback. Owners/Members manage resolution.
     * @path /studios/{studioId}/projects/{projectId}/assets/{assetId}/feedback/{feedbackId}
     * @allow (create) client 'c1' leaves feedback with userId 'c1'
     * @deny (delete) user 'c2' attempts to delete feedback created by 'c1'
     * @principle Relational Integrity: Validates userId against auth UID for creation.
     */
    match /studios/{studioId}/projects/{projectId}/assets/{assetId}/feedback/{feedbackId} {
      allow get: if isStudioOwner(resource.data) || isStudioMember(resource.data) || isAllowedClient(resource.data);
      allow list: if hasStudioAccess(studioId);
      allow create: if isSignedIn() && (isStudioOwner(request.resource.data) || isStudioMember(request.resource.data) || isAllowedClient(request.resource.data)) && request.resource.data.userId == request.auth.uid;
      allow update: if resource != null && (isStudioOwner(resource.data) || isStudioMember(resource.data) || isOwner(resource.data.userId)) && request.resource.data.userId == resource.data.userId;
      allow delete: if resource != null && (isStudioOwner(resource.data) || isStudioMember(resource.data) || isOwner(resource.data.userId));
    }
  }
}